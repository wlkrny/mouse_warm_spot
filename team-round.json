{
  "objective": "PLACEHOLDER: 由领队在 launch 时替换为本轮目标",
  "authority": {
    "allowFilesystemRead": true,
    "allowShellTools": true,
    "allowMutationTools": true
  },
  "steps": [
    {
      "id": "architect",
      "agent": {
        "ref": "package:planner",
        "thinking": "high"
      },
      "task": "PLACEHOLDER: 架构任务 — 读规范→分析→出设计"
    },
    {
      "id": "developer",
      "agent": {
        "ref": "package:worker",
        "tools": ["read", "grep", "find", "ls", "bash", "edit", "write"],
        "thinking": "high"
      },
      "task": "PLACEHOLDER: 开发任务 — 按架构设计实现代码",
      "needs": ["architect"]
    },
    {
      "id": "reviewer",
      "agent": {
        "ref": "package:reviewer",
        "thinking": "high"
      },
      "task": "PLACEHOLDER: 审查任务 — 对照架构和规范审查代码",
      "needs": ["developer"]
    }
  ],
  "limits": {
    "concurrency": 1,
    "timeoutSecondsPerStep": 3600
  }
}
