{
  "objective": "PLACEHOLDER: 由领队替换",
  "authority": {
    "allowFilesystemRead": true,
    "allowShellTools": true,
    "allowMutationTools": true
  },
  "steps": [
    {
      "id": "developer",
      "agent": {
        "ref": "package:worker",
        "tools": ["read", "grep", "find", "ls", "bash", "edit", "write"],
        "thinking": "high"
      },
      "task": "PLACEHOLDER: 开发任务"
    },
    {
      "id": "reviewer",
      "agent": {
        "ref": "package:reviewer",
        "thinking": "high"
      },
      "task": "PLACEHOLDER: 审查任务",
      "needs": ["developer"]
    }
  ],
  "limits": {
    "concurrency": 1,
    "timeoutSecondsPerStep": 1800
  }
}
